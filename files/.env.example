# ============================================================
# TNA Co., Ltd — Medical Supplement Platform
# Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ─── APP ────────────────────────────────────────────────────
NODE_ENV=development
DEBUG=true
APP_NAME="TNA Supplement"
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tna_user:tna_password@localhost:5432/tna_db
DATABASE_URL_SYNC=postgresql://tna_user:tna_password@localhost:5432/tna_db
POSTGRES_USER=tna_user
POSTGRES_PASSWORD=tna_password
POSTGRES_DB=tna_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── REDIS ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=                      # Uncomment if Redis auth enabled

# ─── SECURITY ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

# NextAuth.js
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
NEXTAUTH_URL=http://localhost:3000

# ─── OAUTH (optional) ───────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# ─── STRIPE ─────────────────────────────────────────────────
# Test keys start with sk_test_ / pk_test_
# Live keys start with sk_live_ / pk_live_
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── OMISE (Thai PromptPay) ──────────────────────────────────
OMISE_PUBLIC_KEY=pkey_test_...
OMISE_SECRET_KEY=skey_test_...

# ─── EMAIL (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM="TNA Supplement <no-reply@tna-supplement.com>"
EMAIL_FROM_NAME="TNA Co., Ltd"

# ─── FILE STORAGE (AWS S3 / Cloudflare R2) ──────────────────
S3_BUCKET=tna-products
S3_REGION=ap-southeast-1
S3_ENDPOINT=                          # Leave empty for AWS; set for Cloudflare R2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
CDN_URL=https://cdn.tna-supplement.com  # CloudFront or R2 public URL

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://tna-supplement.com

# ─── CELERY (Background Tasks) ──────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── MONITORING (optional) ──────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ─── ADMIN ──────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@tna-supplement.com
FIRST_ADMIN_PASSWORD=CHANGE_ME_strong_password_here

# ─── PGADMIN (Docker dev only) ──────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
