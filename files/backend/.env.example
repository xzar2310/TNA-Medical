# ─── Backend Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in values. NEVER commit .env to version control.

DATABASE_URL=postgresql+asyncpg://tna_user:tna_password@localhost:5432/tna_db
DATABASE_URL_SYNC=postgresql://tna_user:tna_password@localhost:5432/tna_db

REDIS_URL=redis://localhost:6379/0

# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

ALLOWED_ORIGINS=http://localhost:3000

# Stripe (use sk_test_ in development — never real keys in dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Omise Thai PromptPay
OMISE_SECRET_KEY=skey_test_...
OMISE_PUBLIC_KEY=pkey_test_...

# Resend transactional email
RESEND_API_KEY=re_...
EMAIL_FROM=TNA Supplement <no-reply@tna-supplement.com>

# S3 / Cloudflare R2
S3_BUCKET=tna-products
S3_REGION=ap-southeast-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
CDN_URL=https://cdn.tna-supplement.com

DEBUG=true
FIRST_ADMIN_EMAIL=admin@tna-supplement.com
FIRST_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
